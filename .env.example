# Telegram Bot Token - Get from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# LM Studio URL (OpenAI-compatible API endpoint)
LM_STUDIO_URL=http://localhost:1234/v1

# Default model to use when no model is set in a specific chat
LM_STUDIO_MODEL=llama3.1

# Optional: MCP server configuration
MCP_SERVER_NAME=telegram-mcp
MCP_SERVER_VERSION=1.0.0